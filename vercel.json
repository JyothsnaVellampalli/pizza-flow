{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": { "runtime": "vercel-node@latest" },
    "dist/server.cjs": { "runtime": "vercel-node@latest" }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "dist/server.cjs"
    },
    { 
      "source": "/(.*)", 
      "destination": "/index.html" 
    }
  ]
}
